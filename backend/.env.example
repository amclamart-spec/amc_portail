# ============================================
# Configuration AMC Portail — Backend
# ============================================

PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/amc_portail?schema=public"

JWT_SECRET="votre-secret-jwt-tres-long-et-securise"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_SECRET="votre-secret-refresh-jwt-encore-plus-long"
JWT_REFRESH_EXPIRES_IN="7d"

FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# Google OAuth2 (SSO)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"
# Email runtime via API Abacus
EMAIL_PROVIDER="ABACUS"
EMAIL_FROM_NAME="AMC Portail"
EMAIL_FROM_EMAIL="noreply@musulmansdeclamart.fr"
ABACUS_API_KEY=""
ABACUS_EMAIL_API_BASE_URL="https://apps.abacus.ai"
ABACUS_EMAIL_API_ENDPOINT="/api/v0/send-email"

# Fallback SMTP (si EMAIL_PROVIDER=SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-application"

# Paiements Sandbox
STRIPE_SECRET_KEY=""
STRIPE_PUBLIC_KEY=""
STRIPE_WEBHOOK_SECRET=""

GOCARDLESS_ACCESS_TOKEN=""
GOCARDLESS_WEBHOOK_SECRET=""
GOCARDLESS_ENVIRONMENT="sandbox"

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# Configuration Backend AMC Portail - Démo locale
PORT=4000
NODE_ENV=development

# Base de données PostgreSQL locale
DATABASE_URL="postgresql://amc_user:amc_password@localhost:5432/amc_portail_local?schema=public"

# JWT
JWT_SECRET=amc_demo_jwt_secret_2025_local
JWT_REFRESH_SECRET=amc_demo_jwt_refresh_secret_2025_local
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# SMTP - Mode console pour la démo (pas d'envoi réel)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=AMC Portail
SMTP_FROM_EMAIL=noreply@amc-portail.local
