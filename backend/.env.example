# ============================================
# Configuration AMC Portail — Backend
# ============================================

PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:password@localhost:5432/amc_portail?schema=public"

JWT_SECRET="votre-secret-jwt-tres-long-et-securise"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_SECRET="votre-secret-refresh-jwt-encore-plus-long"
JWT_REFRESH_EXPIRES_IN="7d"

FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# Google OAuth2 (SSO)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"
# Email runtime via Brevo
EMAIL_PROVIDER="BREVO"
EMAIL_FROM_NAME="AMC Portail"
EMAIL_FROM_EMAIL="noreply@musulmansdeclamart.fr"
BREVO_API_KEY=""
# Ancienne option: API Abacus
ABACUS_API_KEY=""
ABACUS_EMAIL_API_BASE_URL="https://apps.abacus.ai"
ABACUS_EMAIL_API_ENDPOINT="/api/v0/send-email"

# Fallback SMTP (si EMAIL_PROVIDER=SMTP ou si Brevo/Abacus échoue)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-application"

# Paiements Sandbox
