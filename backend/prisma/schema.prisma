generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TRESORIER
  PROFESSEUR
  FAMILLE
  RESPONSABLE_POLE_CORAN
  RESPONSABLE_POLE_ARABE
  RESPONSABLE_POLE_SOUTIEN_SCO
  RESPONSABLE_POLE_SCIENCE_IS
  RESPONSABLE_POLE_SOCIAL
  OPERATEUR_SOCIAL
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  passwordHash         String?              @map("password_hash")
  googleId             String?              @unique @map("google_id")
  provider             String?
  role                 Role                 @default(FAMILLE)
  validationStatus     ValidationStatus     @default(PENDING) @map("validation_status")
  firstName            String               @map("first_name")
  lastName             String               @map("last_name")
  phone                String?
  emailVerified        Boolean              @default(false) @map("email_verified")
  emailVerifyToken     String?              @map("email_verify_token")
  resetPasswordToken   String?              @map("reset_password_token")
  resetPasswordExpires DateTime?            @map("reset_password_expires")
  failedLoginAttempts  Int                  @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime?            @map("locked_until")
  refreshToken         String?              @map("refresh_token")
  lastLogin            DateTime?            @map("last_login")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  family               Family?
  teacherProfile       Teacher?
  recordedTransactions PaymentTransaction[] @relation("RecordedByUser")
  refundsManaged       Refund[]             @relation("RefundManagedBy")
  refundCodesGenerated RefundSecurityCode[] @relation("RefundCodeGenerator")
  refundCodesUsed      RefundSecurityCode[] @relation("RefundCodeUser")
  sentMessages         ChatMessage[]        @relation("ChatMessageSender")
  receivedMessages     ChatMessage[]        @relation("ChatMessageRecipient")
  beneficiariesCreated SocialBeneficiary[]  @relation("BeneficiaryCreator")
  casesCreated         SocialCase[]         @relation("CaseCreator")
  casesProcessed       SocialCase[]         @relation("CaseProcessor")
  caseDecisions        CaseDecision[]       @relation("DecisionMaker")
  stockMovements       StockMovement[]      @relation("StockMover")
  socialDistributions  Distribution[]       @relation("DistributionOperator")
  socialCollections    SocialCollection[]   @relation("CollectionOperator")
  purchases            Purchase[]           @relation("PurchaseOperator")
  socialBudgets        SocialBudget[]       @relation("BudgetManager")

  @@map("users")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Family {
  id                String        @id @default(uuid())
  userId            String        @unique @map("user_id")
  familyName        String        @map("family_name")
  addressLine1      String        @map("address_line1")
  addressLine2      String?       @map("address_line2")
  postalCode        String        @map("postal_code")
  city              String
  country           String        @default("France")
  phonePrimary      String        @map("phone_primary")
  phoneSecondary    String?       @map("phone_secondary")
  accountStatus     AccountStatus @default(ACTIVE) @map("account_status")
  notificationPrefs Json?         @default("{\"email\": true, \"sms\": false}") @map("notification_prefs")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parents            Parent[]
  students           Student[]
  payments           Payment[]
  enrollmentConsents EnrollmentConsent[]
  paymentPlans       PaymentPlan[]

  @@map("families")
}

model HomeworkMessage {
  id                 String   @id @default(uuid())
  classId            String   @map("class_id")
  teacherId          String   @map("teacher_id")
  date               DateTime
  body               String
  attachmentUrl      String?  @map("attachment_url")
  attachmentFilename String?  @map("attachment_filename")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, date])
  @@map("homework_messages")
}

enum Civility {
  M
  MME
}

enum ParentLink {
  PERE
  MERE
  TUTEUR_LEGAL
}

model Parent {
  id              String     @id @default(uuid())
  familyId        String     @map("family_id")
  civility        Civility
  lastName        String     @map("last_name")
  firstName       String     @map("first_name")
  email           String?
  phone           String
  link            ParentLink
  isLegalGuardian Boolean    @default(false) @map("is_legal_guardian")
  sortOrder       Int        @default(1) @map("sort_order")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("parents")
}

enum Gender {
  GARCON
  FILLE
}

model Student {
  id                    String   @id @default(uuid())
  familyId              String   @map("family_id")
  lastName              String   @map("last_name")
  firstName             String   @map("first_name")
  dateOfBirth           DateTime @map("date_of_birth")
  gender                Gender
  photoUrl              String?  @map("photo_url")
  allergies             String?
  currentTreatments     String?  @map("current_treatments")
  emergencyContactName  String?  @map("emergency_contact_name")
  emergencyContactPhone String?  @map("emergency_contact_phone")
  medicalCertUrl        String?  @map("medical_cert_url")
  isReturningStudent    Boolean  @default(false) @map("is_returning_student")
  schoolGrade           String?  @map("school_grade")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  family               Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  enrollments          Enrollment[]
  healthForms          StudentHealthForm[]
  enrollmentConsents   EnrollmentConsent[]
  evaluations          Evaluation[]
  coranSeances         CoranSeance[]
  coranRevisions       CoranRevision[]
  coranRepetitions     CoranRepetition[]
  coranLectures        CoranLecture[]
  coranBulletinUploads CoranBulletinUpload[]

  @@map("students")
}

enum SchoolYearPeriod {
  MENSUEL
  TRIMESTRIEL
  SEMESTRIEL
  ANNUEL
}

model SchoolYear {
  id        String   @id @default(uuid())
  label     String   @unique
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  classes            Class[]
  enrollments        Enrollment[]
  payments           Payment[]
  studentHealthForms StudentHealthForm[]
  enrollmentConsents EnrollmentConsent[]
  paymentPlans       PaymentPlan[]

  @@map("school_years")
}

enum RoomStatus {
  ACTIVE
  INACTIVE
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
}

model Room {
  id         String     @id @default(uuid())
  name       String     @unique
  capacity   Int
  equipments String[]   @default([])
  location   String?
  status     RoomStatus @default(ACTIVE)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  timeSlots TimeSlot[]
  classes   Class[]

  @@map("rooms")
}

model TimeSlot {
  id        String   @id @default(uuid())
  dayOfWeek String   @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  roomId    String   @map("room_id")
  poleId    String?  @map("pole_id")
  recurring Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  room           Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  pole           Pole?           @relation(fields: [poleId], references: [id], onDelete: SetNull)
  classes        Class[]
  classTimeSlots ClassTimeSlot[]

  @@index([dayOfWeek, startTime, endTime])
  @@index([roomId, dayOfWeek])
  @@map("time_slots")
}

model ClassTimeSlot {
  classId    String @map("class_id")
  timeSlotId String @map("time_slot_id")
  sortOrder  Int    @default(0) @map("sort_order")

  class    Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  timeSlot TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@id([classId, timeSlotId])
  @@map("class_time_slots")
}

model Teacher {
  id          String        @id @default(uuid())
  userId      String        @unique @map("user_id")
  civility    Civility      @default(M)
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  email       String        @unique
  phone       String?
  specialties String[]      @default([])
  poleId      String?       @map("pole_id")
  status      TeacherStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pole             Pole?             @relation(fields: [poleId], references: [id], onDelete: SetNull)
  classes          Class[]
  homeworkMessages HomeworkMessage[]

  @@map("teachers")
}

model ChatMessage {
  id          String   @id @default(uuid())
  senderId    String   @map("sender_id")
  recipientId String   @map("recipient_id")
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sender    User @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ChatMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@map("chat_messages")
}

model Pole {
  id                  String           @id @default(uuid())
  name                String           @unique
  description         String?
  period              SchoolYearPeriod @default(ANNUEL)
  sortOrder           Int              @default(0) @map("sort_order")
  blockReenrollments  Boolean          @default(false) @map("block_reenrollments")
  blockNewEnrollments Boolean          @default(false) @map("block_new_enrollments")
  createdAt           DateTime         @default(now()) @map("created_at")

  levels    Level[]
  classes   Class[]
  timeSlots TimeSlot[]
  teachers  Teacher[]

  @@map("poles")
}

model Level {
  id          String   @id @default(uuid())
  poleId      String   @map("pole_id")
  code        String
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  minAge      Int?     @map("min_age")
  maxAge      Int?     @map("max_age")
  cursus      String?  @map("cursus")
  createdAt   DateTime @default(now()) @map("created_at")

  pole    Pole    @relation(fields: [poleId], references: [id], onDelete: Cascade)
  classes Class[]

  @@unique([poleId, code])
  @@map("levels")
}

enum ClassStatus {
  OPEN
  CLOSED
  FULL
}

model Class {
  id                 String      @id @default(uuid())
  schoolYearId       String      @map("school_year_id")
  poleId             String?     @map("pole_id")
  levelId            String      @map("level_id")
  timeSlotId         String?     @map("time_slot_id")
  roomId             String?     @map("room_id")
  teacherId          String?     @map("teacher_id")
  dayOfWeek          String      @map("day_of_week")
  startTime          String      @map("start_time")
  endTime            String      @map("end_time")
  room               String?
  teacherName        String?     @map("teacher_name")
  teacherUserId      String?     @map("teacher_user_id")
  capacity           Int         @default(20)
  enrolledCount      Int         @default(0) @map("enrolled_count")
  status             ClassStatus @default(OPEN)
  validFrom          DateTime?   @map("valid_from")
  validTo            DateTime?   @map("valid_to")
  applyEnrollmentFee Boolean     @default(true) @map("apply_enrollment_fee")
  examPreparation    Boolean     @default(false) @map("exam_preparation")
  isProvisional      Boolean     @default(false) @map("is_provisional")
  genre              String      @default("Tout") @map("genre")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  schoolYear           SchoolYear            @relation(fields: [schoolYearId], references: [id])
  pole                 Pole?                 @relation(fields: [poleId], references: [id])
  level                Level                 @relation(fields: [levelId], references: [id])
  timeSlot             TimeSlot?             @relation(fields: [timeSlotId], references: [id])
  roomRef              Room?                 @relation(fields: [roomId], references: [id])
  teacher              Teacher?              @relation(fields: [teacherId], references: [id])
  enrollments          Enrollment[]
  lessons              Lesson[]
  homeworkMessages     HomeworkMessage[]
  classTimeSlots       ClassTimeSlot[]
  coranSeances         CoranSeance[]
  coranBulletinUploads CoranBulletinUpload[]

  @@index([schoolYearId, poleId, levelId])
  @@index([timeSlotId])
  @@index([roomId])
  @@index([teacherId])
  @@map("classes")
}

enum EvaluationStatus {
  on_time
  late
  missing
}

model Lesson {
  id          String   @id @default(uuid())
  classId     String   @map("class_id")
  title       String
  description String?
  date        DateTime
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]

  @@index([classId])
  @@map("lessons")
}

model Evaluation {
  id                  String           @id @default(uuid())
  studentId           String           @map("student_id")
  lessonId            String           @map("lesson_id")
  grade               Float
  appreciation        String?
  submitted           Boolean          @default(false)
  status              EvaluationStatus @default(on_time)
  justification       String?
  familyJustification String?          @map("family_justification")
  justificationStatus String           @default("NONE") @map("justification_status")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([lessonId])
  @@map("evaluations")
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ARCHIVED
}

model Enrollment {
  id               String           @id @default(uuid())
  registrationCode String?          @unique @map("registration_code")
  studentId        String           @map("student_id")
  schoolYearId     String           @map("school_year_id")
  classId          String           @map("class_id")
  status           EnrollmentStatus @default(PENDING)
  comment          String?
  isWaitlist       Boolean          @default(false) @map("is_waitlist")
  waitlistOrder    Int?             @map("waitlist_order")
  levelValidated   Boolean          @default(false) @map("level_validated")
  enrolledAt       DateTime         @default(now()) @map("enrolled_at")
  confirmedAt      DateTime?        @map("confirmed_at")
  cancelledAt      DateTime?        @map("cancelled_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])
  class      Class      @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, schoolYearId])
  @@map("enrollments")
}

model EnrollmentDraft {
  id          String    @id @default(uuid())
  email       String
  profile     String    @default("FAMILLE")
  currentStep Int       @default(1) @map("current_step")
  payload     Json
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@map("enrollment_drafts")
}

enum ConsentType {
  SANITARY_FORM
  ENGAGEMENT
}

enum SignatureMode {
  TYPED
  DRAWN
  CHECKBOX
}

model StudentHealthForm {
  id                         String   @id @default(uuid())
  studentId                  String   @map("student_id")
  schoolYearId               String?  @map("school_year_id")
  hasChronicDisease          Boolean  @default(false) @map("has_chronic_disease")
  chronicDiseaseDetails      String?  @map("chronic_disease_details")
  hasMedicalTreatment        Boolean  @default(false) @map("has_medical_treatment")
  medicalTreatmentDetails    String?  @map("medical_treatment_details")
  hasAllergy                 Boolean  @default(false) @map("has_allergy")
  allergyDetails             String?  @map("allergy_details")
  hasDisability              Boolean  @default(false) @map("has_disability")
  disabilityDetails          String?  @map("disability_details")
  otherUsefulHealthInfo      String?  @map("other_useful_health_info")
  canLeaveAloneAfterClass    Boolean? @map("can_leave_alone_after_class")
  confidentialityAccepted    Boolean  @default(false) @map("confidentiality_accepted")
  noMedicationPolicyAccepted Boolean  @default(false) @map("no_medication_policy_accepted")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  student              Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolYear           SchoolYear?           @relation(fields: [schoolYearId], references: [id], onDelete: SetNull)
  emergencyContacts    EmergencyContact[]
  pickupAuthorizations PickupAuthorization[]

  @@index([studentId, schoolYearId])
  @@map("student_health_forms")
}

model EmergencyContact {
  id           String   @id @default(uuid())
  healthFormId String   @map("health_form_id")
  lastName     String   @map("last_name")
  firstName    String   @map("first_name")
  relationship String
  phone        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  healthForm StudentHealthForm @relation(fields: [healthFormId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

model PickupAuthorization {
  id           String   @id @default(uuid())
  healthFormId String   @map("health_form_id")
  fullName     String   @map("full_name")
  relationship String
  phone        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  healthForm StudentHealthForm @relation(fields: [healthFormId], references: [id], onDelete: Cascade)

  @@map("pickup_authorizations")
}

model EnrollmentConsent {
  id                   String        @id @default(uuid())
  familyId             String        @map("family_id")
  studentId            String?       @map("student_id")
  schoolYearId         String?       @map("school_year_id")
  consentType          ConsentType   @map("consent_type")
  textVersion          String        @default("v1") @map("text_version")
  accepted             Boolean       @default(false)
  acceptedAt           DateTime?     @map("accepted_at")
  acceptedByFullName   String        @map("accepted_by_full_name")
  acceptedByRole       String?       @map("accepted_by_role")
  citySigned           String?       @map("city_signed")
  signedAt             DateTime?     @map("signed_at")
  signatureMode        SignatureMode @default(TYPED) @map("signature_mode")
  signatureData        String?       @map("signature_data")
  legalMentionAccepted Boolean       @default(false) @map("legal_mention_accepted")
  legalMentionLabel    String?       @map("legal_mention_label")
  ipAddress            String?       @map("ip_address")
  userAgent            String?       @map("user_agent")
  documentSnapshot     String?       @map("document_snapshot")
  metadata             Json?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  family     Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  student    Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  schoolYear SchoolYear? @relation(fields: [schoolYearId], references: [id], onDelete: SetNull)

  @@index([familyId, consentType])
  @@map("enrollment_consents")
}

enum PaymentPlanType {
  STRIPE_CARD
  STRIPE_SEPA
  GO_CARDLESS_SEPA
  CHEQUE
  ESPECES
}

enum PaymentPlanStatus {
  DRAFT
  PENDING
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

model PaymentPlan {
  id                String            @id @default(uuid())
  familyId          String            @map("family_id")
  schoolYearId      String?           @map("school_year_id")
  paymentId         String?           @unique @map("payment_id")
  type              PaymentPlanType
  status            PaymentPlanStatus @default(DRAFT)
  installmentsCount Int               @default(1) @map("installments_count")
  scheduleDay       Int?              @map("schedule_day")
  totalAmount       Decimal           @db.Decimal(10, 2)
  mandateId         String?           @map("mandate_id")
  providerRef       String?           @map("provider_ref")
  metadata          Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  family     Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  schoolYear SchoolYear? @relation(fields: [schoolYearId], references: [id], onDelete: SetNull)
  payment    Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([familyId, status])
  @@map("payment_plans")
}

model PricingConfig {
  id                    String   @id @default(uuid())
  isActive              Boolean  @default(true) @map("is_active")
  registrationFee       Decimal  @default(10.00) @map("registration_fee") @db.Decimal(10, 2)
  fraisPrelevement      Decimal  @default(0.00) @map("frais_prelevement") @db.Decimal(10, 2)
  arabicTier1           Decimal  @default(310.00) @map("arabic_tier_1") @db.Decimal(10, 2)
  arabicTier2           Decimal  @default(570.00) @map("arabic_tier_2") @db.Decimal(10, 2)
  arabicTier3           Decimal  @default(750.00) @map("arabic_tier_3") @db.Decimal(10, 2)
  arabicTier4           Decimal  @default(900.00) @map("arabic_tier_4") @db.Decimal(10, 2)
  arabicTier5           Decimal  @default(1050.00) @map("arabic_tier_5") @db.Decimal(10, 2)
  arabicExtraPerStudent Decimal  @default(150.00) @map("arabic_extra_per_student") @db.Decimal(10, 2)
  coranEnfant           Decimal  @default(220.00) @map("coran_enfant") @db.Decimal(10, 2)
  coranAdulteHomme      Decimal  @default(300.00) @map("coran_adulte_homme") @db.Decimal(10, 2)
  coranAdulteFemme      Decimal  @default(250.00) @map("coran_adulte_femme") @db.Decimal(10, 2)
  sciencesIslamiques    Decimal  @default(300.00) @map("sciences_islamiques") @db.Decimal(10, 2)
  tariffRows            Json?    @map("tariff_rows")
  createdById           String?  @map("created_by_id")
  updatedById           String?  @map("updated_by_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("pricing_configs")
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  CHEQUE
  ESPECES
  VIREMENT
  CB
  SEPA
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  OVERDUE
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  OFFLINE
  STRIPE
  GOCARDLESS
  PAYPAL
}

model Payment {
  id                   String          @id @default(uuid())
  familyId             String          @map("family_id")
  schoolYearId         String          @map("school_year_id")
  totalAmount          Decimal         @map("total_amount") @db.Decimal(10, 2)
  paidAmount           Decimal         @default(0) @map("paid_amount") @db.Decimal(10, 2)
  registrationFee      Decimal         @default(10.00) @map("registration_fee") @db.Decimal(10, 2)
  arabicFee            Decimal         @default(0) @map("arabic_fee") @db.Decimal(10, 2)
  coranScienceFee      Decimal         @default(0) @map("coran_science_fee") @db.Decimal(10, 2)
  paymentMethod        PaymentMethod?  @map("payment_method")
  provider             PaymentProvider @default(OFFLINE)
  externalPaymentId    String?         @map("external_payment_id")
  currency             String          @default("EUR")
  numberOfInstallments Int             @default(1) @map("number_of_installments")
  status               PaymentStatus   @default(PENDING)
  sepaMandate          String?         @map("sepa_mandate")
  metadata             Json?
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  family           Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  schoolYear       SchoolYear           @relation(fields: [schoolYearId], references: [id])
  installments     Installment[]
  paymentPlan      PaymentPlan?
  transactions     PaymentTransaction[]
  refunds          Refund[]
  financialEntries FinancialEntry[]

  @@map("payments")
}

enum InstallmentStatus {
  UPCOMING
  PAID
  FAILED
  CANCELLED
}

model Installment {
  id                String            @id @default(uuid())
  paymentId         String            @map("payment_id")
  installmentNumber Int               @map("installment_number")
  amount            Decimal           @db.Decimal(10, 2)
  dueDate           DateTime          @map("due_date")
  status            InstallmentStatus @default(UPCOMING)
  paidAt            DateTime?         @map("paid_at")
  transactionRef    String?           @map("transaction_ref")
  chequeNumber      String?           @map("cheque_number")
  comment           String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("installments")
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum TransactionStatus {
  INITIATED
  SUCCEEDED
  FAILED
  CANCELLED
}

model PaymentTransaction {
  id           String            @id @default(uuid())
  paymentId    String            @map("payment_id")
  provider     PaymentProvider
  method       PaymentMethod
  type         TransactionType   @default(PAYMENT)
  status       TransactionStatus @default(INITIATED)
  amount       Decimal           @db.Decimal(10, 2)
  currency     String            @default("EUR")
  externalRef  String?           @map("external_ref")
  payerName    String?           @map("payer_name")
  description  String?
  metadata     Json?
  recordedById String?           @map("recorded_by_id")
  processedAt  DateTime?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  payment    Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation("RecordedByUser", fields: [recordedById], references: [id])

  @@map("payment_transactions")
}

enum RefundStatus {
  PENDING
  PROCESSED
  REJECTED
}

model Refund {
  id            String       @id @default(uuid())
  paymentId     String       @map("payment_id")
  transactionId String?      @map("transaction_id")
  amount        Decimal      @db.Decimal(10, 2)
  reason        String
  status        RefundStatus @default(PENDING)
  requestedBy   String?      @map("requested_by")
  approvedById  String?      @map("approved_by_id")
  processedAt   DateTime?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  payment    Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  approvedBy User?   @relation("RefundManagedBy", fields: [approvedById], references: [id])

  @@map("refunds")
}

model RefundSecurityCode {
  id          String    @id @default(uuid())
  code        String    @unique
  generatedBy String    @map("generated_by")
  usedBy      String?   @map("used_by")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  generator User  @relation("RefundCodeGenerator", fields: [generatedBy], references: [id])
  user      User? @relation("RefundCodeUser", fields: [usedBy], references: [id])

  @@map("refund_security_codes")
}

enum FinancialEntryType {
  INCOME
  EXPENSE
}

model FinancialCategory {
  id          String             @id @default(uuid())
  name        String             @unique
  type        FinancialEntryType
  description String?
  isSystem    Boolean            @default(false) @map("is_system")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  entries FinancialEntry[]

  @@map("financial_categories")
}

model FinancialEntry {
  id           String             @id @default(uuid())
  categoryId   String             @map("category_id")
  paymentId    String?            @map("payment_id")
  entryType    FinancialEntryType @map("entry_type")
  amount       Decimal            @db.Decimal(10, 2)
  description  String?
  entryDate    DateTime           @default(now()) @map("entry_date")
  schoolYearId String?            @map("school_year_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  category FinancialCategory @relation(fields: [categoryId], references: [id])
  payment  Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@map("financial_entries")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ═══════════════════════════════════════════════════════════════════════════════
//  PÔLE SOCIAL
// ═══════════════════════════════════════════════════════════════════════════════

enum SocialCaseStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REFUSED
  SUSPENDED
  EXPIRED
}

enum StockMovementType {
  COLLECTE
  ACHAT
  DISTRIBUTION
  CORRECTION
  RETOUR
}

enum DistributionStatus {
  VALIDATED
  CANCELLED
}

enum SocialCollectionStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

model SocialBeneficiary {
  id            String   @id @default(uuid())
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String?
  phone         String?
  addressLine1  String?  @map("address_line1")
  postalCode    String?  @map("postal_code")
  city          String?
  adultsCount   Int      @default(1) @map("adults_count")
  childrenCount Int      @default(0) @map("children_count")
  monthlyIncome Decimal? @map("monthly_income") @db.Decimal(10, 2)
  observations  String?
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creator       User           @relation("BeneficiaryCreator", fields: [createdBy], references: [id])
  cases         SocialCase[]
  distributions Distribution[]

  @@index([lastName, firstName])
  @@map("social_beneficiaries")
}

model SocialCase {
  id            String            @id @default(uuid())
  beneficiaryId String            @map("beneficiary_id")
  status        SocialCaseStatus  @default(DRAFT)
  autoDecision  SocialCaseStatus? @map("auto_decision")
  autoScore     Json?             @map("auto_score")
  observations  String?
  createdBy     String            @map("created_by")
  processedBy   String?           @map("processed_by")
  processedAt   DateTime?         @map("processed_at")
  expiresAt     DateTime?         @map("expires_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  beneficiary SocialBeneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  creator     User              @relation("CaseCreator", fields: [createdBy], references: [id])
  processor   User?             @relation("CaseProcessor", fields: [processedBy], references: [id])
  decisions   CaseDecision[]

  @@index([beneficiaryId, status])
  @@map("social_cases")
}

model CaseDecision {
  id               String           @id @default(uuid())
  caseId           String           @map("case_id")
  decision         SocialCaseStatus
  isAuto           Boolean          @default(false) @map("is_auto")
  reason           String?
  criteriaSnapshot Json?            @map("criteria_snapshot")
  userId           String           @map("user_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  case SocialCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User       @relation("DecisionMaker", fields: [userId], references: [id])

  @@index([caseId])
  @@map("case_decisions")
}

model EligibilityCriteria {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  description String?
  type        String
  operator    String   @default("LTE")
  numValue    Decimal? @map("num_value") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("eligibility_criteria")
}

model SocialProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products SocialProduct[]

  @@map("social_product_categories")
}

model SocialProduct {
  id             String   @id @default(uuid())
  categoryId     String   @map("category_id")
  name           String
  unit           String   @default("unité")
  stockQty       Decimal  @default(0) @map("stock_qty") @db.Decimal(10, 2)
  alertThreshold Decimal  @default(0) @map("alert_threshold") @db.Decimal(10, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category          SocialProductCategory @relation(fields: [categoryId], references: [id])
  stockMovements    StockMovement[]
  distributionLines DistributionLine[]
  collectionLines   CollectionLine[]
  purchaseLines     PurchaseLine[]

  @@index([categoryId, isActive])
  @@map("social_products")
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String            @map("product_id")
  type          StockMovementType
  quantity      Decimal           @db.Decimal(10, 2)
  unit          String
  referenceId   String?           @map("reference_id")
  referenceType String?           @map("reference_type")
  comment       String?
  userId        String            @map("user_id")
  createdAt     DateTime          @default(now()) @map("created_at")

  product SocialProduct @relation(fields: [productId], references: [id])
  user    User          @relation("StockMover", fields: [userId], references: [id])

  @@index([productId, type])
  @@index([referenceId, referenceType])
  @@map("stock_movements")
}

model Distribution {
  id            String             @id @default(uuid())
  beneficiaryId String             @map("beneficiary_id")
  caseId        String?            @map("case_id")
  status        DistributionStatus @default(VALIDATED)
  distributedAt DateTime           @map("distributed_at")
  observations  String?
  cancelledAt   DateTime?          @map("cancelled_at")
  cancelReason  String?            @map("cancel_reason")
  userId        String             @map("user_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  beneficiary SocialBeneficiary  @relation(fields: [beneficiaryId], references: [id])
  user        User               @relation("DistributionOperator", fields: [userId], references: [id])
  lines       DistributionLine[]

  @@index([beneficiaryId, status])
  @@index([distributedAt])
  @@map("distributions")
}

model DistributionLine {
  id             String  @id @default(uuid())
  distributionId String  @map("distribution_id")
  productId      String  @map("product_id")
  quantity       Decimal @db.Decimal(10, 2)
  unit           String

  distribution Distribution  @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  product      SocialProduct @relation(fields: [productId], references: [id])

  @@map("distribution_lines")
}

model SocialCollection {
  id           String                 @id @default(uuid())
  reference    String?
  label        String
  type         String                 @default("GENERAL")
  location     String?
  status       SocialCollectionStatus @default(DRAFT)
  collectedAt  DateTime               @map("collected_at")
  observations String?
  userId       String                 @map("user_id")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  user  User             @relation("CollectionOperator", fields: [userId], references: [id])
  lines CollectionLine[]

  @@index([status, collectedAt])
  @@map("social_collections")
}

model CollectionLine {
  id           String  @id @default(uuid())
  collectionId String  @map("collection_id")
  productId    String  @map("product_id")
  quantity     Decimal @db.Decimal(10, 2)
  unit         String

  collection SocialCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    SocialProduct    @relation(fields: [productId], references: [id])

  @@map("collection_lines")
}

model Supplier {
  id           String   @id @default(uuid())
  name         String
  contact      String?
  phone        String?
  email        String?
  address      String?
  isActive     Boolean  @default(true) @map("is_active")
  observations String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  purchases Purchase[]

  @@map("suppliers")
}

model Purchase {
  id           String         @id @default(uuid())
  reference    String?
  supplierId   String?        @map("supplier_id")
  budgetId     String?        @map("budget_id")
  status       PurchaseStatus @default(DRAFT)
  purchasedAt  DateTime       @map("purchased_at")
  totalAmount  Decimal        @map("total_amount") @db.Decimal(10, 2)
  description  String?
  observations String?
  validatedAt  DateTime?      @map("validated_at")
  userId       String         @map("user_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  supplier Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  budget   SocialBudget?  @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  user     User           @relation("PurchaseOperator", fields: [userId], references: [id])
  lines    PurchaseLine[]

  @@index([status, purchasedAt])
  @@map("purchases")
}

model PurchaseLine {
  id         String  @id @default(uuid())
  purchaseId String  @map("purchase_id")
  productId  String  @map("product_id")
  quantity   Decimal @db.Decimal(10, 2)
  unit       String
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(10, 2)

  purchase Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  SocialProduct @relation(fields: [productId], references: [id])

  @@map("purchase_lines")
}

model SocialBudget {
  id           String   @id @default(uuid())
  year         Int      @unique
  totalAmount  Decimal  @map("total_amount") @db.Decimal(10, 2)
  observations String?
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user      User       @relation("BudgetManager", fields: [userId], references: [id])
  purchases Purchase[]

  @@map("social_budgets")
}

// ---------------------------------------------------------------------------
// Module Suivi Coran
// ---------------------------------------------------------------------------

enum CoranAppreciation {
  TRES_BIEN
  BIEN
  A_REVOIR
}

enum CoranRevisionType {
  NOUVELLE_PAGE
  ANCIENNE_PAGE
}

model SourateCoran {
  id            String   @id @default(uuid())
  numero        Int      @unique
  nomArabe      String   @map("nom_arabe")
  nomFr         String   @map("nom_fr")
  nombreVersets Int      @map("nombre_versets")
  nombrePages   Float    @map("nombre_pages")
  createdAt     DateTime @default(now()) @map("created_at")

  seances     CoranSeance[]
  revisions   CoranRevision[]
  repetitions CoranRepetition[]
  lectures    CoranLecture[]

  @@map("sourates_coran")
}

model CoranSeance {
  id                   String             @id @default(uuid())
  studentId            String             @map("student_id")
  classId              String             @map("class_id")
  sourateId            String             @map("sourate_id")
  date                 DateTime
  pageDebut            Int                @map("page_debut")
  pageFin              Int                @map("page_fin")
  noteMemorisation     CoranAppreciation? @map("note_memorisation")
  noteRevisionNouvelle CoranAppreciation? @map("note_revision_nouvelle")
  noteRevisionAncienne CoranAppreciation? @map("note_revision_ancienne")
  noteTajwid           CoranAppreciation? @map("note_tajwid")
  commentaire          String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  sourate SourateCoran @relation(fields: [sourateId], references: [id])

  @@index([studentId, date])
  @@index([classId])
  @@map("coran_seances")
}

model CoranRevision {
  id              String             @id @default(uuid())
  studentId       String             @map("student_id")
  sourateId       String             @map("sourate_id")
  pageDebut       Int                @map("page_debut")
  pageFin         Int                @map("page_fin")
  type            CoranRevisionType
  date            DateTime
  appreciation    CoranAppreciation?
  commentaireProf String?            @map("commentaire_prof")
  evaluatedAt     DateTime?          @map("evaluated_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sourate SourateCoran @relation(fields: [sourateId], references: [id])

  @@index([studentId, date])
  @@map("coran_revisions")
}

model CoranRepetition {
  id              String             @id @default(uuid())
  studentId       String             @map("student_id")
  numeroPage      Int                @map("numero_page")
  sourateId       String?            @map("sourate_id")
  compteur        Int                @default(0)
  derniereDate    DateTime?          @map("derniere_date")
  appreciation    CoranAppreciation?
  commentaireProf String?            @map("commentaire_prof")
  evaluatedAt     DateTime?          @map("evaluated_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sourate SourateCoran? @relation(fields: [sourateId], references: [id])

  @@unique([studentId, numeroPage])
  @@map("coran_repetitions")
}

model CoranLecture {
  id              String             @id @default(uuid())
  studentId       String             @map("student_id")
  sourateId       String             @map("sourate_id")
  pageDebut       Int                @map("page_debut")
  pageFin         Int                @map("page_fin")
  date            DateTime
  dureeMinutes    Int?               @map("duree_minutes")
  commentaire     String?
  appreciation    CoranAppreciation?
  commentaireProf String?            @map("commentaire_prof")
  evaluatedAt     DateTime?          @map("evaluated_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sourate SourateCoran @relation(fields: [sourateId], references: [id])

  @@index([studentId, date])
  @@map("coran_lectures")
}

model CoranBulletinUpload {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  classId      String   @map("class_id")
  fileUrl      String   @map("file_url")
  fileName     String   @map("file_name")
  uploadedById String   @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@map("coran_bulletin_uploads")
}
